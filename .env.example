# Cafe24 앱 설정 (카페24 개발자센터에서 복사)
CAFE24_CLIENT_ID=여기에_Client_ID_입력
CAFE24_CLIENT_SECRET=여기에_Client_Secret_Key_입력
CAFE24_REDIRECT_URI=https://여기에_내_Vercel_주소.vercel.app/auth/callback

# Supabase 설정 (supabase.com 에서 복사)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_key_입력
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_key_입력

# 앱 주소 (Vercel 배포 후 입력)
NEXT_PUBLIC_APP_URL=https://여기에_내_Vercel_주소.vercel.app
